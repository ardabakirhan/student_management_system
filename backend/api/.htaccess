# Pass Authorization header through to PHP (Apache strips it by default)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Block direct browser/HTTP access to config.php
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Return JSON 403 instead of Apache's HTML error page
ErrorDocument 403 '{"error":"Forbidden"}'
